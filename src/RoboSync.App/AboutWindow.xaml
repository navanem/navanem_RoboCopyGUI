<Window x:Class="RoboSync.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:RoboSync.App"
        Title="About RoboSync"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}" FontFamily="Segoe UI">
    <Border Padding="26">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="56" Height="56" CornerRadius="14" Background="{StaticResource AccentBrush}">
                    <TextBlock Text="RS" FontSize="22" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static app:AppInfo.Name}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{x:Static app:AppInfo.VendorLine}" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="8,0,0,4" />
                    </StackPanel>
                    <TextBlock Text="{x:Static app:AppInfo.VersionDisplay}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="{x:Static app:AppInfo.Description}" Margin="0,20,0,0"
                       TextWrapping="Wrap" FontSize="13" LineHeight="20"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <TextBlock Margin="0,18,0,0" FontSize="13">
                <Run Text="Website:" Foreground="#8B949E" />
                <Hyperlink NavigateUri="{x:Static app:AppInfo.Website}" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}">
                    <Run Text="www.navanem.com" />
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="{x:Static app:AppInfo.Copyright}" Margin="0,16,0,0"
                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Text="Built on the native Windows Robocopy engine. Licensed under MIT."
                       Margin="0,4,0,0" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />

            <Button Content="Close" Style="{StaticResource PrimaryButton}" MinWidth="100"
                    HorizontalAlignment="Right" Margin="0,22,0,0" Click="OnClose" />
        </StackPanel>
    </Border>
</Window>
